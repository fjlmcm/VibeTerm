---
import type { Locale } from '../../i18n';
import { useTranslations } from '../../i18n';
import { CJK_ISSUES, CJK_POINTS } from '../../data/cjk-showdown';
import { SHOWDOWN_URL } from '../../lib/site';

interface Props {
  lang: Locale;
}
const { lang } = Astro.props;
const t = useTranslations(lang);
---

<section id="cjk" class="cjk">
  <div class="container">
    <header class="head">
      <p class="kicker" data-reveal>{t('section.cjk.kicker')}</p>
      <h2 class="section-title" data-reveal>{t('section.cjk.title')}</h2>
      <p class="lede" data-reveal>{t('section.cjk.subtitle')}</p>
    </header>

    <div class="table" data-reveal>
      <div class="row head-row mono">
        <span>{t('cjk.table.tool')}</span>
        <span>{t('cjk.table.issue')}</span>
        <span class="col-st">{t('cjk.table.status')}</span>
      </div>
      {
        CJK_ISSUES.map((it) => (
          <a class="row" href={it.url} target="_blank" rel="noopener noreferrer">
            <span class="tool mono">{it.tool}</span>
            <span class="issue">
              {it.summary}
              <span class="ref mono">{it.ref}</span>
              {it.thumbs ? <span class="thumbs mono">▲ {it.thumbs}</span> : null}
            </span>
            <span class="col-st">
              <span class:list={['badge', it.status]}>{t(`cjk.status.${it.status}`)}</span>
            </span>
          </a>
        ))
      }
    </div>

    <div class="answer" data-reveal>
      <h3 class="answer-title mono">{t('cjk.vibeterm.title')}</h3>
      <ul class="points">
        {
          CJK_POINTS.map((p) => (
            <li>
              <svg class="check" viewBox="0 0 24 24" width="18" height="18" aria-hidden="true">
                <path
                  d="M20 6 9 17l-5-5"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="2.5"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                />
              </svg>
              <span>{t(`cjk.point.${p}`)}</span>
            </li>
          ))
        }
      </ul>
    </div>

    <p class="foot" data-reveal>
      <span class="conclusion">{t('cjk.conclusion')}</span>
      <a class="showdown-link mono" href={SHOWDOWN_URL} target="_blank" rel="noopener noreferrer">
        {t('cjk.showdownLink')} →
      </a>
    </p>
  </div>
</section>

<style>
  .cjk {
    padding-block: var(--space-section);
  }
  .head {
    max-width: 64ch;
    margin-bottom: 3rem;
  }

  /* 竞品 issue 表 */
  .table {
    border: 1px solid var(--glass-brd);
    border-radius: var(--radius);
    overflow: hidden;
    background: var(--glass-bg);
    -webkit-backdrop-filter: blur(var(--glass-blur)) saturate(1.3);
    backdrop-filter: blur(var(--glass-blur)) saturate(1.3);
  }
  .row {
    display: grid;
    grid-template-columns: 9rem 1fr 7rem;
    gap: 1rem;
    align-items: center;
    padding: 0.85rem 1.2rem;
    border-bottom: 1px solid var(--border);
    font-size: var(--text-sm);
    color: var(--text);
    transition: background var(--dur-fast) var(--ease-out-quart);
  }
  .row:last-child {
    border-bottom: none;
  }
  .head-row {
    background: color-mix(in oklab, var(--surface) 70%, transparent);
    color: var(--text-dim);
    font-size: var(--text-xs);
    letter-spacing: 0.14em;
    text-transform: uppercase;
  }
  a.row:hover {
    background: color-mix(in oklab, var(--accent) 10%, transparent);
  }
  .tool {
    font-weight: 600;
    color: var(--text-dim);
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }
  .issue {
    display: inline-flex;
    flex-wrap: wrap;
    align-items: baseline;
    gap: 0.5rem;
    line-height: 1.5;
  }
  a.row:hover .issue {
    color: var(--accent);
  }
  .ref {
    font-size: var(--text-xs);
    color: var(--text-dim);
    opacity: 0.8;
  }
  .thumbs {
    font-size: var(--text-xs);
    color: var(--st-waiting);
  }
  .col-st {
    text-align: right;
  }
  .badge {
    display: inline-block;
    padding: 0.2rem 0.55rem;
    border-radius: 99px;
    font-size: var(--text-xs);
    font-weight: 600;
    white-space: nowrap;
    border: 1px solid currentColor;
  }
  .badge.open {
    color: var(--st-stalled);
  }
  .badge.closed-unfixed {
    color: var(--text-dim);
  }
  .badge.partial {
    color: var(--st-waiting);
  }

  /* VibeTerm 答卷 */
  .answer {
    margin-top: 2.5rem;
    padding: 2rem;
    border: 1px solid color-mix(in oklab, var(--accent) 35%, var(--border));
    border-radius: var(--radius);
    background: color-mix(in oklab, var(--accent) 7%, transparent);
  }
  .answer-title {
    font-size: var(--text-lg);
    font-weight: 700;
    margin-bottom: 1.3rem;
  }
  .points {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1rem 2rem;
  }
  .points li {
    display: flex;
    gap: 0.7rem;
    align-items: flex-start;
    font-size: var(--text-sm);
    line-height: 1.55;
  }
  .check {
    flex: none;
    margin-top: 0.1rem;
    color: var(--st-done);
  }

  .foot {
    display: flex;
    flex-wrap: wrap;
    justify-content: space-between;
    align-items: baseline;
    gap: 1rem;
    margin-top: 2rem;
    font-size: var(--text-sm);
    color: var(--text-dim);
  }
  .conclusion {
    max-width: 60ch;
  }
  .showdown-link {
    color: var(--accent);
    white-space: nowrap;
    transition: opacity var(--dur-fast);
  }
  .showdown-link:hover {
    opacity: 0.75;
  }

  @media (max-width: 680px) {
    .row {
      grid-template-columns: 1fr auto;
      grid-template-areas:
        'tool status'
        'issue issue';
      gap: 0.4rem 1rem;
    }
    .tool {
      grid-area: tool;
    }
    .col-st {
      grid-area: status;
    }
    .issue {
      grid-area: issue;
    }
    .points {
      grid-template-columns: 1fr;
    }
  }
</style>
