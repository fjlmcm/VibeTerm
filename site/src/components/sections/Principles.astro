---
import type { Locale } from '../../i18n';
import { useTranslations } from '../../i18n';

interface Props {
  lang: Locale;
}
const { lang } = Astro.props;
const t = useTranslations(lang);

const items = [
  { k: 'zeroIntrusion', tag: '00', wide: true },
  { k: 'multiAgent', tag: '01', wide: false },
  { k: 'terminal', tag: '02', wide: false },
  { k: 'cjk', tag: '03', wide: false },
  { k: 'privacy', tag: '04', wide: false },
  { k: 'oss', tag: '05', wide: false },
];
---

<section id="why" class="principles">
  <div class="container">
    <p class="kicker" data-reveal>{t('section.principles.kicker')}</p>
    <h2 class="section-title" data-reveal>{t('section.principles.title')}</h2>

    <div class="grid">
      {
        items.map((it, i) => (
          <article
            class:list={['p-card', { wide: it.wide }]}
            data-reveal
            data-reveal-delay={`${Math.min(i, 4) * 55}ms`}
          >
            <span class="tag mono">{it.tag}</span>
            <h3>{t(`principle.${it.k}.title`)}</h3>
            <p>{t(`principle.${it.k}.desc`)}</p>
          </article>
        ))
      }
    </div>
  </div>
</section>

<style>
  .principles {
    padding-block: var(--space-section);
  }
  .grid {
    margin-top: 2.5rem;
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1rem;
  }
  .p-card {
    position: relative;
    padding: 1.6rem;
    border: 1px solid var(--glass-brd);
    border-radius: var(--radius);
    background: var(--glass-bg);
    -webkit-backdrop-filter: blur(var(--glass-blur)) saturate(1.3);
    backdrop-filter: blur(var(--glass-blur)) saturate(1.3);
    overflow: hidden;
    transition:
      border-color var(--dur-normal) var(--ease-out-quart),
      transform var(--dur-normal) var(--ease-out-quart),
      background var(--dur-normal);
  }
  .p-card::before {
    content: '';
    position: absolute;
    inset: 0 auto 0 0;
    width: 2px;
    background: var(--accent);
    transform: scaleY(0);
    transform-origin: top;
    transition: transform var(--dur-normal) var(--ease-out-expo);
  }
  .p-card:hover {
    border-color: var(--glass-brd-hi);
    transform: translateY(-4px);
    background: var(--glass-bg-strong);
    box-shadow: var(--shadow-glow);
  }
  .p-card:hover::before {
    transform: scaleY(1);
  }
  .p-card.wide {
    grid-column: span 1;
  }
  .tag {
    color: var(--accent);
    font-size: var(--text-sm);
    font-weight: 600;
    letter-spacing: 0.1em;
  }
  .p-card h3 {
    font-size: var(--text-lg);
    margin: 0.7rem 0 0.5rem;
    letter-spacing: -0.01em;
  }
  .p-card p {
    color: var(--text-dim);
    font-size: var(--text-sm);
    line-height: 1.6;
  }

  @media (max-width: 900px) {
    .grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }
  @media (max-width: 560px) {
    .grid {
      grid-template-columns: 1fr;
    }
  }
</style>
