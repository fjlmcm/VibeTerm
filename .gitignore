# Tauri build
src-tauri/target/
src-tauri/gen/

# Rust workspace
**/target/
**/*.rs.bk

# Node
node_modules/
web/dist/
web/packages/*/dist/
.pnpm-store/

# Playwright
e2e/test-results/
e2e/playwright-report/
e2e/playwright/.cache/

# Logs
*.log
npm-debug.log*
pnpm-debug.log*
yarn-debug.log*
yarn-error.log*

# Secrets (signing keys must never be committed)
.env
.env.*
!.env.example
*.p12
*.cer
*.mobileprovision
src-tauri/private/

# OS
.DS_Store
Thumbs.db

# Reference projects (read-only, cloned for inspiration — never tracked)
references/

# IDE
.vscode/
.idea/
*.swp
*.swo

# Coverage
coverage/
*.lcov

# Smoke artifacts
.smoke/

# Local scratch (audio test files, throwaway experiments)
tmp/

# Claude Code 本地 agent 运行时状态(scheduled_tasks.lock 等)忽略,
# 但跟踪 .claude/skills/(项目级可调用 skill,如发版流程,应随仓库走)。
.claude/*
!.claude/skills/
